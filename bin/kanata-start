#!/usr/bin/env bash
set -euo pipefail

# Kanata start helper script
# Starts kanata manually with sudo (required for VirtualHIDDevice access)

CONFIG_FILE="${KANATA_CONFIG_FILE:-${HOME}/.config/kanata/kanata.kbd}"
KANATA_BIN="${KANATA_BIN:-/opt/homebrew/bin/kanata}"
PID_FILE="${KANATA_PID_FILE:-/tmp/kanata.pid}"
CONFIG_DIR="$(dirname "$CONFIG_FILE")"
OUT_LOG="${KANATA_OUT_LOG:-${CONFIG_DIR}/kanata.out.log}"
ERR_LOG="${KANATA_ERR_LOG:-${CONFIG_DIR}/kanata.err.log}"

echo "Starting Kanata..."

# Check config file
if [ ! -f "$CONFIG_FILE" ]; then
  echo "❌ Config file not found: $CONFIG_FILE"
  exit 1
fi

# Resolve kanata binary path
if [ ! -x "$KANATA_BIN" ]; then
  KANATA_BIN="$(command -v kanata 2>/dev/null || true)"
fi

if [ -z "${KANATA_BIN}" ] || [ ! -x "${KANATA_BIN}" ]; then
  echo "❌ kanata binary not found. Expected /opt/homebrew/bin/kanata or PATH entry."
  exit 1
fi

# Ensure sudo credential is available before background start
if ! sudo -v; then
  echo "❌ sudo authentication failed"
  exit 1
fi

# Check if process is already running
if pgrep -x kanata >/dev/null 2>&1; then
  echo "⚠️  Kanata is already running"
  ps aux | grep -i kanata | grep -v grep | grep -v kanata-start | sed 's/^/  /'
  exit 0
fi

# Reset logs so status only reflects the latest start attempt
: >"$OUT_LOG"
: >"$ERR_LOG"

# Start as background process with root privileges
sudo -n /bin/sh -c 'nohup "$1" --cfg "$2" >> "$3" 2>> "$4" & echo $! > "$5"' _ \
  "$KANATA_BIN" "$CONFIG_FILE" "$OUT_LOG" "$ERR_LOG" "$PID_FILE"

KANATA_PID="$(cat "$PID_FILE" 2>/dev/null || true)"

sleep 1 # Give it a moment to start and check if the process is running
if [ -n "$KANATA_PID" ] && ps -p "$KANATA_PID" >/dev/null 2>&1; then
  echo "✅ Kanata started successfully (PID: $KANATA_PID)"
  echo "   Stop: kanata-stop"
  echo "   Status: kanata-status"
else
  echo "❌ Failed to start Kanata"
  echo
  echo "Check error log:"
  echo "  tail -f $ERR_LOG"
  echo
  echo "Check permissions in System Settings:"
  echo "  Privacy & Security > Input Monitoring"
  echo "  Privacy & Security > Accessibility"
  exit 1
fi
